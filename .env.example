# ===========================================
# ATHENA ERP - Variables de Entorno
# ===========================================
# Copie este archivo como .env y complete los valores

# ===========================================
# DJANGO (BACKEND)
# ===========================================

# Production: False | Development: True
DJANGO_DEBUG=True

# Secret key para Django (generar con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
DJANGO_SECRET_KEY=tu-secret-key-aqui

# URL del frontend
FRONTEND_URL=http://localhost:5173

# ===========================================
# BASE DE DATOS (POSTGRESQL)
# ===========================================

POSTGRES_DB=athena_erp
POSTGRES_USER=athena_user
POSTGRES_PASSWORD=tu-password-aqui
POSTGRES_HOST=db
POSTGRES_PORT=5432

# URL completa para Django (se construye con las variables anteriores)
DATABASE_URL=postgres://athena_user:tu-password-aqui@db:5432/athena_erp

# ===========================================
# DOCKER
# ===========================================

# Puerto del backend
BACKEND_PORT=8000

# Puerto de PostgreSQL (solo para acceso externo, no necesario para la app)
POSTGRES_EXTERNAL_PORT=5432